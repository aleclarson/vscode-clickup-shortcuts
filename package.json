{
  "name": "clickup-shortcuts",
  "displayName": "ClickUp Shortcuts",
  "description": "View and copy ClickUp task names/descriptions",
  "publisher": "aleclarson",
  "icon": "icon.png",
  "version": "1.1.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:clickup-shortcuts.listTasks",
    "onCommand:clickup-shortcuts.checkoutTaskBranch"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clickup-shortcuts.listTasks",
        "title": "ClickUp: List Tasks and Copy"
      },
      {
        "command": "clickup-shortcuts.checkoutTaskBranch",
        "title": "ClickUp: Checkout task branch"
      }
    ],
    "configuration": {
      "title": "ClickUp",
      "properties": {
        "clickup.apiToken": {
          "type": "string",
          "default": "",
          "description": "ClickUp Personal API Token"
        },
        "clickup.spaceId": {
          "type": "string",
          "default": "",
          "description": "ClickUp Space ID"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run bundle",
    "bundle": "tsup",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "format": "prettier --write .",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aleclarson/vscode-clickup-shortcuts"
  },
  "license": "MIT"
}
